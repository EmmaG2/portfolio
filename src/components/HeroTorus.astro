---
/* src/components/HeroTorus.astro - OPTIMIZACIÓN MÁXIMA (MatCap Edition) */
---

<canvas id="hero-canvas" aria-hidden="true"></canvas>
<div id="hero-sentinel" aria-hidden="true" style="position:absolute;top:0;left:0;width:1px;height:100vh;pointer-events:none;"></div>

<script>
  import * as THREE from 'three'

  /* ── MatCap Generator (The "Elite" Trick) ── */
  // Instead of lights, we "draw" the material appearance once on a 256px circle.
  // The GPU then just maps this circle to the geometry's normals. 
  // Result: Stunning quality, 0 lighting calculation cost.
  function generateMatcap(color: string, dark: boolean): THREE.CanvasTexture {
    const size = 256
    const canvas = document.createElement('canvas')
    canvas.width = size; canvas.height = size
    const ctx = canvas.getContext('2d')
    if (!ctx) return new THREE.CanvasTexture(canvas)

    const center = size / 2
    const radius = size / 2

    // Base color
    ctx.beginPath()
    ctx.arc(center, center, radius, 0, Math.PI * 2)
    ctx.fillStyle = color
    ctx.fill()

    // Main highlight (The "Shiny" spot)
    const highlight = ctx.createRadialGradient(center * 0.7, center * 0.7, 0, center * 0.7, center * 0.7, radius * 0.8)
    highlight.addColorStop(0, dark ? 'rgba(255, 255, 255, 0.4)' : 'rgba(255, 255, 255, 0.6)')
    highlight.addColorStop(1, 'rgba(255, 255, 255, 0)')
    ctx.fillStyle = highlight
    ctx.fill()

    // Rim light (The "Glow" on edges)
    const rim = ctx.createRadialGradient(center, center, radius * 0.8, center, center, radius)
    rim.addColorStop(0, 'rgba(0, 0, 0, 0)')
    rim.addColorStop(1, dark ? 'rgba(255, 255, 255, 0.2)' : 'rgba(0, 0, 0, 0.1)')
    ctx.fillStyle = rim
    ctx.fill()

    // Glassy refraction simulation (Bottom highlight)
    const bottomLight = ctx.createRadialGradient(center * 1.3, center * 1.3, 0, center * 1.3, center * 1.3, radius * 0.6)
    bottomLight.addColorStop(0, dark ? 'rgba(255, 255, 255, 0.15)' : 'rgba(255, 255, 255, 0.3)')
    bottomLight.addColorStop(1, 'rgba(0, 0, 0, 0)')
    ctx.fillStyle = bottomLight
    ctx.fill()

    const texture = new THREE.CanvasTexture(canvas)
    texture.colorSpace = THREE.SRGBColorSpace
    return texture
  }

  function initTorus() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null
    if (!canvas || canvas.dataset.init === '1') return
    canvas.dataset.init = '1'

    const isMobile = window.innerWidth < 768
    // High-quality geometry but optimized segments
    const TUBE_SEG   = isMobile ? 32 : 48
    const RADIAL_SEG = isMobile ? 96 : 160

    const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark'
    const getAccentColor = (): string => 
      localStorage.getItem('fg-accent') ?? (isDark() ? '#E85C73' : '#C47A0A')

    const renderer = new THREE.WebGLRenderer({
      canvas, 
      antialias: true, // With MatCap, we can afford antialiasing easily
      alpha: true, 
      powerPreference: 'high-performance'
    })
    
    renderer.setSize(window.innerWidth, window.innerHeight)
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5))
    renderer.outputColorSpace = THREE.SRGBColorSpace

    const scene  = new THREE.Scene()
    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100)
    camera.position.z = isMobile ? 8 : 6

    const geometry = new THREE.TorusGeometry(1.8, 0.62, TUBE_SEG, RADIAL_SEG)
    const material = new THREE.MeshMatcapMaterial({ transparent: true, opacity: 0.95 })
    
    const group = new THREE.Group()
    const torus = new THREE.Mesh(geometry, material)
    torus.rotation.x = -Math.PI * 0.12
    group.add(torus)
    scene.add(group)

    // Initial MatCap generation
    let currentMatcap = generateMatcap(getAccentColor(), isDark())
    material.matcap = currentMatcap

    const pointer = { x: 0, y: 0 }, smooth = { x: 0, y: 0 }
    const clock = new THREE.Clock()

    function animate() {
      const delta = Math.min(clock.getDelta(), 0.1)
      
      smooth.x += (pointer.x - smooth.x) * (delta * 3)
      smooth.y += (pointer.y - smooth.y) * (delta * 3)
      
      torus.rotation.y += delta * 0.25
      group.rotation.y = smooth.x * 0.18
      group.rotation.x = -smooth.y * 0.1
      
      renderer.render(scene, camera)
    }

    renderer.setAnimationLoop(animate)

    const resizeObserver = new ResizeObserver(() => {
        const w = window.innerWidth, h = window.innerHeight
        camera.aspect = w / h
        camera.updateProjectionMatrix()
        renderer.setSize(w, h)
    })
    resizeObserver.observe(document.body)

    const onMove = (x: number, y: number) => {
      pointer.x = (x / window.innerWidth - 0.5) * 2
      pointer.y = (y / window.innerHeight - 0.5) * 2
    }
    window.addEventListener('mousemove', (e) => onMove(e.clientX, e.clientY))
    window.addEventListener('touchmove', (e) => onMove(e.touches[0].clientX, e.touches[0].clientY), { passive: true })

    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { clock.start(); renderer.setAnimationLoop(animate) }
      else { renderer.setAnimationLoop(null) }
    })
    const sentinel = document.getElementById('hero-sentinel')
    if (sentinel) io.observe(sentinel)

    // Reactivity (Dynamic MatCap generation on-the-fly)
    const updateLook = () => {
      const newMatcap = generateMatcap(getAccentColor(), isDark())
      if (material.matcap) material.matcap.dispose()
      material.matcap = newMatcap
      material.needsUpdate = true
    }
    
    document.addEventListener('theme-changed',  updateLook)
    document.addEventListener('accent-changed', updateLook)

    document.addEventListener('astro:before-swap', () => {
      renderer.setAnimationLoop(null)
      resizeObserver.disconnect()
      io.disconnect()
      geometry.dispose()
      material.dispose()
      if (material.matcap) material.matcap.dispose()
      renderer.dispose()
      document.removeEventListener('theme-changed', updateLook)
      document.removeEventListener('accent-changed', updateLook)
    }, { once: true })
  }

  initTorus()
  document.addEventListener('astro:page-load', initTorus)
</script>

<style>
  #hero-canvas {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>
