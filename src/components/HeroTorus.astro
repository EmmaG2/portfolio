---
/* src/components/HeroTorus.astro - MULTI-THREADED EDITION */
---

<canvas id="hero-canvas" aria-hidden="true"></canvas>

<script>
  function initTorus() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.init === '1') return;

    const supportsOffscreen = 'transferControlToOffscreen' in canvas;

    if (supportsOffscreen) {
      canvas.dataset.init = '1';
      
      // Initialize Web Worker using Vite's constructor
      const worker = new Worker(
        new URL('../scripts/hero-worker.ts', import.meta.url),
        { type: 'module' }
      );

      const offscreen = canvas.transferControlToOffscreen();
      const isMobile = window.innerWidth < 768;
      
      const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark';
      const getAccentColor = (): string => 
        localStorage.getItem('fg-accent') ?? (isDark() ? '#E85C73' : '#C47A0A');

      // Send initial data to worker
      worker.postMessage({
        type: 'init',
        payload: {
          canvas: offscreen,
          width: window.innerWidth,
          height: window.innerHeight,
          pixelRatio: Math.min(window.devicePixelRatio, 1.5),
          isMobile,
          accentColor: getAccentColor()
        }
      }, [offscreen]);

      // Proxy Events to Worker
      const onMove = (x: number, y: number) => {
        worker.postMessage({
          type: 'mousemove',
          payload: {
            x: (x / window.innerWidth - 0.5) * 2,
            y: (y / window.innerHeight - 0.5) * 2
          }
        });
      };

      window.addEventListener('mousemove', (e) => onMove(e.clientX, e.clientY));
      window.addEventListener('touchmove', (e) => onMove(e.touches[0].clientX, e.touches[0].clientY), { passive: true });

      const resizeObserver = new ResizeObserver(() => {
        worker.postMessage({
          type: 'resize',
          payload: { width: window.innerWidth, height: window.innerHeight }
        });
      });
      resizeObserver.observe(document.body);

      // Listen for ready signal to fade in
      worker.onmessage = (e) => {
        if (e.data.type === 'ready') {
          canvas.style.opacity = '1';
        }
      };

      // Reactivity
      const updateColor = () => {
        worker.postMessage({ type: 'update-color', payload: { color: getAccentColor() } });
      };
      document.addEventListener('theme-changed',  updateColor);
      document.addEventListener('accent-changed', updateColor);

      // Cleanup
      document.addEventListener('astro:before-swap', () => {
        worker.terminate();
        resizeObserver.disconnect();
        document.removeEventListener('theme-changed', updateColor);
        document.removeEventListener('accent-changed', updateColor);
      }, { once: true });

    } else {
      // Fallback to Main Thread if no OffscreenCanvas support
      console.warn('OffscreenCanvas not supported, falling back to main thread.');
      import('./HeroTorusFallback').then(m => m.init(canvas));
    }
  }

  // Use requestIdleCallback to not block initial paint
  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => initTorus());
  } else {
    setTimeout(initTorus, 200);
  }
  
  document.addEventListener('astro:page-load', initTorus);
</script>

<style>
  #hero-canvas {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.33, 1, 0.68, 1);
  }
</style>
