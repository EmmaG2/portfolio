---
/* src/components/HeroTorus.astro */
---

<canvas id="hero-canvas" aria-hidden="true"></canvas>
<!-- Sentinel: observed to pause rendering when hero is out of view -->
<div id="hero-sentinel" aria-hidden="true" style="position:absolute;top:0;left:0;width:1px;height:100vh;pointer-events:none;"></div>

<script>
  import * as THREE from 'three'
  import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js'

  interface LightDef {
    type: 'dir' | 'point'
    color: number
    intensity: number
    pos: [number, number, number]
    dist?: number
  }
  interface Preset {
    color: string; metalness: number; roughness: number
    transmission: number; thickness: number
    clearcoat: number; clearcoatRoughness: number
    iridescence: number; iridescenceIOR: number; iridescenceRange: [number, number]
    envMapIntensity: number; ambientColor: number; ambientIntensity: number
    lights: LightDef[]
  }

  const LIGHT_HQ: Preset = {
    color: '#C47A0A', metalness: 0.15, roughness: 0.08,
    transmission: 0.22, thickness: 1.8,
    clearcoat: 0.6, clearcoatRoughness: 0.08,
    iridescence: 0.5, iridescenceIOR: 1.6, iridescenceRange: [80, 450],
    envMapIntensity: 1.6, ambientColor: 0xfff8e8, ambientIntensity: 0.8,
    lights: [
      { type: 'dir',   color: 0xfff0cc, intensity: 5,  pos: [-3,  6, 4]  },
      { type: 'point', color: 0xff8800, intensity: 10, pos: [ 4, -1, 3], dist: 15 },
    ],
  }
  const DARK_HQ: Preset = {
    color: '#E85C73', metalness: 0.1, roughness: 0.08,
    transmission: 0.35, thickness: 2.2,
    clearcoat: 0.8, clearcoatRoughness: 0.08,
    iridescence: 0.7, iridescenceIOR: 1.8, iridescenceRange: [80, 600],
    envMapIntensity: 2.0, ambientColor: 0x0a0000, ambientIntensity: 0.8,
    lights: [
      { type: 'dir',   color: 0xff88aa, intensity: 5,   pos: [-4,  5,  3]  },
      { type: 'point', color: 0xff3060, intensity: 10,  pos: [ 4, -0.5, 3], dist: 15 },
    ],
  }

  function initTorus() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null
    if (!canvas || canvas.dataset.init === '1') return
    canvas.dataset.init = '1'

    const isMobile = window.innerWidth < 768
    // Optimizamos segmentos: 128 radiales para nitidez sin lag
    const TUBE_SEG   = isMobile ? 24 : 32
    const RADIAL_SEG = isMobile ? 64 : 128

    const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark'
    const getAccentColor = (): string =>
      localStorage.getItem('fg-accent') ?? (isDark() ? '#E85C73' : '#C47A0A')

    const renderer = new THREE.WebGLRenderer({
      canvas, 
      antialias: !isMobile,
      alpha: true, 
      powerPreference: 'high-performance',
    })
    
    renderer.setSize(window.innerWidth, window.innerHeight)
    // Cap pixel ratio a 1.5 para evitar sobrecarga en pantallas Retina
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5))
    renderer.toneMapping = THREE.ACESFilmicToneMapping
    renderer.outputColorSpace = THREE.SRGBColorSpace

    const scene  = new THREE.Scene()
    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100)
    camera.position.z = isMobile ? 8 : 6

    // Generar entorno (RoomEnvironment)
    const pmrem = new THREE.PMREMGenerator(renderer)
    const envTexture = pmrem.fromScene(new RoomEnvironment(), 0.04).texture
    scene.environment = envTexture
    pmrem.dispose()

    const geometry = new THREE.TorusGeometry(1.8, 0.62, TUBE_SEG, RADIAL_SEG)
    const material = new THREE.MeshPhysicalMaterial({
        transparent: true,
        roughness: 0.08,
        metalness: 0.1
    })
    
    const group = new THREE.Group()
    const torus = new THREE.Mesh(geometry, material)
    torus.rotation.x = -Math.PI * 0.12
    group.add(torus)
    scene.add(group)

    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5)
    scene.add(ambientLight)
    
    const managedLights: THREE.Light[] = []

    function applyPreset(preset: Preset, accentOverride?: string) {
      const col = accentOverride ?? preset.color
      material.color.set(col)
      material.transmission = preset.transmission
      material.thickness = preset.thickness
      material.iridescence = preset.iridescence
      material.envMapIntensity = preset.envMapIntensity
      material.clearcoat = preset.clearcoat
      material.clearcoatRoughness = preset.clearcoatRoughness
      
      managedLights.forEach(l => scene.remove(l))
      managedLights.length = 0
      
      preset.lights.forEach(def => {
        const light = def.type === 'dir' 
          ? new THREE.DirectionalLight(def.color, def.intensity)
          : new THREE.PointLight(def.color, def.intensity, def.dist)
        light.position.set(...def.pos)
        scene.add(light)
        managedLights.push(light)
      })
    }

    applyPreset(isDark() ? DARK_HQ : LIGHT_HQ, getAccentColor())

    const pointer = { x: 0, y: 0 }, smooth = { x: 0, y: 0 }
    const clock = new THREE.Clock()

    function animate() {
      const delta = Math.min(clock.getDelta(), 0.1) // Cap delta para evitar tirones
      
      smooth.x += (pointer.x - smooth.x) * (delta * 2.5)
      smooth.y += (pointer.y - smooth.y) * (delta * 2.5)
      
      torus.rotation.y += delta * 0.2
      group.rotation.y = smooth.x * 0.15
      group.rotation.x = -smooth.y * 0.1
      
      renderer.render(scene, camera)
    }

    renderer.setAnimationLoop(animate)

    // ResizeObserver es más eficiente que el evento resize global
    const resizeObserver = new ResizeObserver(() => {
        const w = window.innerWidth, h = window.innerHeight
        camera.aspect = w / h
        camera.updateProjectionMatrix()
        renderer.setSize(w, h)
        // No es necesario actualizar el pixelRatio en cada resize a menos que cambie de monitor
    })
    resizeObserver.observe(document.body)

    const onMove = (x: number, y: number) => {
      pointer.x = (x / window.innerWidth - 0.5) * 2
      pointer.y = (y / window.innerHeight - 0.5) * 2
    }

    window.addEventListener('mousemove', (e) => onMove(e.clientX, e.clientY))
    window.addEventListener('touchmove', (e) => onMove(e.touches[0].clientX, e.touches[0].clientY), { passive: true })

    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        clock.start()
        renderer.setAnimationLoop(animate)
      } else {
        renderer.setAnimationLoop(null)
      }
    })
    const sentinel = document.getElementById('hero-sentinel')
    if (sentinel) io.observe(sentinel)

    // Reactividad
    const onThemeChanged = (e: any) => applyPreset(e.detail.dark ? DARK_HQ : LIGHT_HQ, getAccentColor())
    const onAccentChanged = (e: any) => { material.color.set(e.detail.color); material.needsUpdate = true }
    
    document.addEventListener('theme-changed', onThemeChanged as EventListener)
    document.addEventListener('accent-changed', onAccentChanged as EventListener)

    document.addEventListener('astro:before-swap', () => {
      renderer.setAnimationLoop(null)
      resizeObserver.disconnect()
      io.disconnect()
      geometry.dispose()
      material.dispose()
      envTexture.dispose()
      renderer.dispose()
      document.removeEventListener('theme-changed', onThemeChanged as EventListener)
      document.removeEventListener('accent-changed', onAccentChanged as EventListener)
    }, { once: true })
  }

  initTorus()
  document.addEventListener('astro:page-load', initTorus)
</script>

<style>
  #hero-canvas {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
</style>
