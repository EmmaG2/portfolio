---
import type { CollectionEntry } from 'astro:content'
import TechStack from './TechStack.astro'
import ArrowLink from '../ui/ArrowLink.astro'
import AccentLabel from '../ui/AccentLabel.astro'

interface Props {
  project: CollectionEntry<'projects'>
  index: number
  variant?: 'featured' | 'list'
}

const { project, index, variant = 'featured' } = Astro.props
const { title, tagline, category, year, tech, metrics, coverImage, coverAlt } =
  project.data

const indexLabel = String(index).padStart(2, '0')
---

<article class:list={['project-card', `project-card--${variant}`]} data-reveal>
  <a href={`/work/${project.id}`} class="project-card__image-link" tabindex="-1" aria-hidden="true">
    <div class="project-card__image-wrap">
      <img
        src={coverImage}
        alt={coverAlt}
        loading="lazy"
        decoding="async"
        class="project-card__image"
      />
    </div>
  </a>

  <div class="project-card__body">
    <div class="project-card__meta">
      <AccentLabel text={indexLabel} />
      <AccentLabel text={`${category} · ${year}`} />
    </div>

    <h2 class="project-card__title">
      <a href={`/work/${project.id}`}>{title}</a>
    </h2>

    <p class="project-card__tagline">{tagline}</p>

    {
      metrics && metrics.length > 0 && (
        <ul class="project-card__metrics" aria-label="Key results">
          {metrics.slice(0, 3).map((m) => (
            <li>
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </li>
          ))}
        </ul>
      )
    }

    <TechStack technologies={tech} variant="compact" />

    <ArrowLink href={`/work/${project.id}`} label="Read Case Study" />
  </div>
</article>

<style>
  .project-card {
    display: grid;
    gap: var(--space-6);
  }

  .project-card--featured {
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .project-card--list {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      align-items: start;
    }
  }

  .project-card__image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slower) var(--ease-out-cubic);
  }

  .project-card__image-link:hover .project-card__image {
    transform: scale(1.03);
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .project-card__meta {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .project-card__title a {
    text-decoration: none;
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out-cubic);
  }

  .project-card__title a:hover {
    color: var(--color-accent);
  }

  .project-card__tagline {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .project-card__metrics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .project-card__metrics li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .metric-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    line-height: 1;
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
</style>
