---
import { getCollection } from 'astro:content'
import ProjectCard from '../work/ProjectCard.astro'
import SectionTitle from '../ui/SectionTitle.astro'
import AccentLabel from '../ui/AccentLabel.astro'
import ArrowLink from '../ui/ArrowLink.astro'

const allProjects = await getCollection('projects')
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 2)
---

<section class="work-preview" id="work" aria-labelledby="work-heading">
  <div class="work-preview__header">
    <AccentLabel text="Selected Work" />
    <SectionTitle
      heading="Things I've shipped."
      subheading="Deep dives into real problems and real solutions."
      level={2}
    />
  </div>

  <ul class="work-preview__list" role="list">
    {
      featured.map((project, i) => (
        <li>
          <ProjectCard project={project} index={i + 1} variant="list" />
        </li>
      ))
    }
  </ul>

  <div class="work-preview__footer" data-reveal>
    <ArrowLink href="/work" label="View All Work" />
  </div>
</section>

<style>
  .work-preview {
    padding: var(--space-32) var(--container-padding);
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .work-preview__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .work-preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  .work-preview__footer {
    display: flex;
    justify-content: flex-end;
  }
</style>
