---
import HeroTorus from '../HeroTorus.astro'
import Icon from '../ui/Icon.astro'
---

<section class="hero" aria-label="Introduction">
  <HeroTorus />

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content">
    <p class="hero__label">Software Engineer</p>

    <h1 class="hero__name">
      <span class="hero__name-line">Fernando</span>
      <span class="hero__name-line">Granados</span>
    </h1>

    <p class="hero__tagline">Building digital experiences for 5+ years</p>

    <div class="hero__scroll" aria-hidden="true">
      <Icon name="mouse" size={24} class="hero__scroll-icon" />
    </div>
  </div>
</section>

<div class="hero__separator" aria-hidden="true"></div>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
  }

  /* Gradient overlay — light/dark adaptive */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--color-bg) 0%,
      color-mix(in srgb, var(--color-bg) 70%, transparent) 30%,
      color-mix(in srgb, var(--color-bg) 20%, transparent) 55%,
      transparent 72%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Content block */
  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding-inline: var(--container-padding);
    padding-bottom: var(--space-10);
    max-width: 900px;
    width: 100%;
  }

  /* "SOFTWARE ENGINEER" label */
  .hero__label {
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1vw, 0.78rem);
    font-weight: var(--weight-medium);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Name — massive display */
  .hero__name {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: clamp(4.5rem, 15vw, 11rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-transform: uppercase;
  }

  .hero__name-line {
    display: block;
  }

  /* Tagline */
  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1.5vw, 1.1rem);
    font-weight: var(--weight-regular);
    color: var(--color-text-secondary);
    margin: var(--space-1) 0 0;
    letter-spacing: 0.01em;
  }

  /* Scroll indicator */
  .hero__scroll {
    margin-top: var(--space-6);
    color: var(--color-text-muted);
  }

  .hero__scroll-icon {
    display: block;
    animation: scroll-bounce 1.8s var(--ease-in-out-cubic) infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50%       { transform: translateY(8px); opacity: 0.4; }
  }

  /* Bottom separator */
  .hero__separator {
    height: 1px;
    background: var(--color-border-subtle);
    max-width: var(--container-max);
    margin-inline: auto;
    margin-inline: var(--container-padding);
  }

  /* ─── Tablet ─── */
  @media (max-width: 768px) {
    .hero__name {
      font-size: clamp(3.5rem, 18vw, 7rem);
    }

    .hero__content {
      padding-bottom: var(--space-8);
    }
  }

  /* ─── Mobile ─── */
  @media (max-width: 480px) {
    .hero__content {
      gap: var(--space-2);
      padding-bottom: var(--space-6);
    }

    .hero__scroll {
      margin-top: var(--space-4);
    }
  }
</style>
