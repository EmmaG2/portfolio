---
import Icon from './Icon.astro'

interface Props {
  href: string
  label: string
  external?: boolean
}

const { href, label, external = false } = Astro.props
const attrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {}
---

<a href={href} class="arrow-link" {...attrs}>
  <span>{label}</span>
  <Icon name="arrow-right" size={16} />
</a>

<style>
  .arrow-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap var(--duration-normal) var(--ease-out-cubic);
  }

  .arrow-link:hover {
    gap: var(--space-4);
  }

  .arrow-link :global(svg) {
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-out-cubic);
  }

  .arrow-link:hover :global(svg) {
    transform: translateX(var(--space-1));
  }
</style>
