---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href)
---

<header role="banner">
  <nav aria-label="Main navigation">
    <ul class="nav-list nav-list--left">
      <li>
        <a
          href="/about"
          aria-current={isActive('/about') ? 'page' : undefined}
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/work"
          aria-current={isActive('/work') ? 'page' : undefined}
        >
          Work
        </a>
      </li>
    </ul>

    <a href="/" class="nav-logo" aria-label="Fernando Granados — Home">
      FG
    </a>

    <ul class="nav-list nav-list--right">
      <li>
        <a
          href="/contact"
          aria-current={isActive('/contact') ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
    </ul>

    <button
      class="nav-hamburger"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
      type="button"
    >
      <span class="nav-hamburger__bar"></span>
      <span class="nav-hamburger__bar"></span>
    </button>
  </nav>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="mobile-menu__list">
        <li>
          <a
            href="/about"
            aria-current={isActive('/about') ? 'page' : undefined}
          >
            About
          </a>
        </li>
        <li>
          <a
            href="/work"
            aria-current={isActive('/work') ? 'page' : undefined}
          >
            Work
          </a>
        </li>
        <li>
          <a
            href="/contact"
            aria-current={isActive('/contact') ? 'page' : undefined}
          >
            Contact
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function initNav() {
    const btn = document.querySelector('.nav-hamburger') as HTMLButtonElement | null
    const menu = document.getElementById('mobile-menu')
    if (!btn || !menu) return

    const open = () => {
      btn.setAttribute('aria-expanded', 'true')
      menu.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
      btn.setAttribute('aria-label', 'Close navigation menu')
    }

    const close = () => {
      btn.setAttribute('aria-expanded', 'false')
      menu.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
      btn.setAttribute('aria-label', 'Open navigation menu')
    }

    btn.addEventListener('click', () => {
      btn.getAttribute('aria-expanded') === 'true' ? close() : open()
    })

    menu.querySelectorAll('a').forEach(link => link.addEventListener('click', close))
  }

  document.addEventListener('astro:page-load', initNav)
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    padding: var(--space-5) var(--container-padding);
  }

  nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-10);
  }

  .nav-list--right {
    justify-content: flex-end;
  }

  .nav-list a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-cubic);
    position: relative;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .nav-list a::after {
    content: '';
    position: absolute;
    bottom: 8px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width var(--duration-normal) var(--ease-out-cubic);
  }

  .nav-list a:hover {
    color: var(--color-text-primary);
  }

  .nav-list a:hover::after,
  .nav-list a[aria-current='page']::after {
    width: 100%;
  }

  .nav-list a[aria-current='page'] {
    color: var(--color-accent);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
    transition: color var(--duration-fast) var(--ease-out-cubic);
    justify-self: center;
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  /* ─── Hamburger button ─── */
  .nav-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-3);
    justify-self: end;
    grid-column: 3;
    z-index: calc(var(--z-sticky) + 1);
    position: relative;
  }

  .nav-hamburger__bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition:
      transform var(--duration-normal) var(--ease-out-cubic),
      opacity var(--duration-normal) var(--ease-out-cubic);
    transform-origin: center;
  }

  .nav-hamburger[aria-expanded='true'] .nav-hamburger__bar:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .nav-hamburger[aria-expanded='true'] .nav-hamburger__bar:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* ─── Mobile menu overlay ─── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--color-bg);
    z-index: var(--z-overlay);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out-cubic);
  }

  .mobile-menu[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    text-align: center;
  }

  .mobile-menu__list a {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 10vw, 4rem);
    font-weight: var(--weight-bold);
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
    transition: color var(--duration-fast) var(--ease-out-cubic);
  }

  .mobile-menu__list a:hover,
  .mobile-menu__list a[aria-current='page'] {
    color: var(--color-accent);
  }

  /* ─── Responsive breakpoints ─── */
  @media (max-width: 639px) {
    nav {
      grid-template-columns: 1fr auto 1fr;
    }

    .nav-list {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }

    .nav-logo {
      grid-column: 2;
    }
  }
</style>
