---
/* src/components/layout/SiteNav.astro */
import Icon from '../ui/Icon.astro'

interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href)

const navLinks = [
  { label: 'EXPERIENCE', href: '/about#experience' },
  { label: 'CONTACT',    href: '/contact' },
  { label: 'ABOUT',      href: '/about' },
  { label: 'PROJECTS',   href: '/work' },
  { label: 'BLOG',       href: '/blog' },
]

const accentColors = [
  { hex: '#E85C73', label: 'Rosa' },
  { hex: '#D4890A', label: 'Ámbar' },
  { hex: '#EA580C', label: 'Naranja' },
  { hex: '#10B981', label: 'Esmeralda' },
  { hex: '#8B5CF6', label: 'Violeta' },
]
---

<header role="banner">
  <div class="nav-top-line" aria-hidden="true"></div>

  <nav aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Fernando Granados — Home">FG</a>

    <!-- Desktop Links (Hidden on mobile) -->
    <ul class="nav-links" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[{ active: isActive(href) }]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Shared Controls (Visible on Desktop AND Mobile) -->
    <div class="nav-right-container">
      <div class="nav-controls">
        <div class="color-picker" id="color-picker">
          <button
            class="color-picker__trigger"
            id="color-picker-btn"
            aria-label="Select accent color"
            aria-expanded="false"
            aria-haspopup="listbox"
            type="button"
          >
            <span class="color-picker__dot" id="color-dot"></span>
            <Icon name="chevron-down" size={14} class="color-picker__chevron" />
          </button>

          <div class="color-picker__panel" id="color-panel" role="listbox" aria-label="Accent colors" hidden>
            {accentColors.map(({ hex, label }) => (
              <button
                class="color-swatch"
                data-color={hex}
                role="option"
                aria-label={label}
                title={label}
                type="button"
                style={`background-color: ${hex}`}
              />
            ))}
          </div>
        </div>

        <button
          class="theme-toggle"
          id="theme-toggle"
          aria-label="Toggle color theme"
          type="button"
        >
          <Icon name="sun" size={18} class="icon-sun" />
          <Icon name="moon" size={18} class="icon-moon" />
        </button>
      </div>

      <button
        class="nav-hamburger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
        type="button"
      >
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
      </button>
    </div>
  </nav>

  <div class="nav-bottom-border" aria-hidden="true"></div>

  <!-- Mobile Overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="mobile-menu__list">
        {navLinks.map(({ label, href }) => (
          <li>
            <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  function initNav() {
    const html = document.documentElement
    const pickerBtnCheck = document.getElementById('color-picker-btn') as HTMLButtonElement | null
    if (!pickerBtnCheck || pickerBtnCheck.dataset.init === '1') return
    pickerBtnCheck.dataset.init = '1'

    const toggleBtn = document.getElementById('theme-toggle') as HTMLButtonElement | null
    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const isDark = html.getAttribute('data-theme') === 'dark'
        if (isDark) {
          html.removeAttribute('data-theme')
          localStorage.setItem('fg-theme', 'light')
          document.dispatchEvent(new CustomEvent('theme-changed', { detail: { dark: false } }))
        } else {
          html.setAttribute('data-theme', 'dark')
          localStorage.setItem('fg-theme', 'dark')
          document.dispatchEvent(new CustomEvent('theme-changed', { detail: { dark: true } }))
        }
      })
    }

    const pickerBtn = document.getElementById('color-picker-btn') as HTMLButtonElement | null
    const pickerPanel = document.getElementById('color-panel') as HTMLElement | null
    const dot = document.getElementById('color-dot') as HTMLElement | null
    const swatches = document.querySelectorAll<HTMLButtonElement>('.color-swatch')

    function applyAccent(hex: string) {
      html.style.setProperty('--color-accent', hex)
      html.style.setProperty('--color-accent-hover', hex)
      if (dot) dot.style.backgroundColor = hex
      localStorage.setItem('fg-accent', hex)
      document.dispatchEvent(new CustomEvent('accent-changed', { detail: { color: hex } }))
    }

    function syncDot() {
      if (!dot) return
      const current = getComputedStyle(html).getPropertyValue('--color-accent').trim()
      dot.style.backgroundColor = current || '#D4890A'
    }

    syncDot()

    if (pickerBtn && pickerPanel) {
      pickerBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        const open = pickerPanel.hidden
        pickerPanel.hidden = !open
        pickerBtn.setAttribute('aria-expanded', String(open))
      })
      document.addEventListener('click', () => {
        pickerPanel.hidden = true
        pickerBtn.setAttribute('aria-expanded', 'false')
      })
      pickerPanel.addEventListener('click', (e) => e.stopPropagation())
    }

    swatches.forEach(swatch => {
      swatch.addEventListener('click', () => {
        const color = swatch.dataset.color
        if (color) {
          applyAccent(color)
          if (pickerPanel) pickerPanel.hidden = true
          if (pickerBtn) pickerBtn.setAttribute('aria-expanded', 'false')
        }
      })
    })

    const hamburger = document.querySelector('.nav-hamburger') as HTMLButtonElement | null
    const mobileMenu = document.getElementById('mobile-menu')

    const openMenu = () => {
      hamburger?.setAttribute('aria-expanded', 'true')
      mobileMenu?.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
      hamburger?.setAttribute('aria-label', 'Close navigation menu')
    }

    const closeMenu = () => {
      hamburger?.setAttribute('aria-expanded', 'false')
      mobileMenu?.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
      hamburger?.setAttribute('aria-label', 'Open navigation menu')
    }

    hamburger?.addEventListener('click', () => {
      hamburger.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu()
    })

    mobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu))
  }

  initNav()
  document.addEventListener('astro:page-load', initNav)
</script>

<style>
  .nav-top-line {
    height: 3px;
    background: var(--color-accent);
    transition: background var(--duration-normal) var(--ease-out-cubic);
  }

  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background: var(--color-bg);
    transition: background var(--duration-normal) var(--ease-out-cubic);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--container-padding);
    max-width: var(--container-max);
    margin-inline: auto;
    gap: var(--space-4);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-cubic);
    flex-shrink: 0;
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-8);
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-cubic);
    position: relative;
    padding-bottom: 2px;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width var(--duration-normal) var(--ease-out-cubic);
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  .nav-right-container {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .color-picker {
    position: relative;
  }

  .color-picker__trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    transition: background var(--duration-fast) var(--ease-out-cubic);
  }

  .color-picker__trigger:hover {
    background: var(--color-surface);
  }

  .color-picker__dot {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .color-picker__chevron {
    transition: transform var(--duration-fast) var(--ease-out-cubic);
  }

  .color-picker__trigger[aria-expanded="true"] .color-picker__chevron {
    transform: rotate(180deg);
  }

  .color-picker__panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    right: 0;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
    display: flex;
    gap: var(--space-2);
    box-shadow: var(--shadow-lg);
    z-index: var(--z-dropdown);
  }

  .color-picker__panel[hidden] {
    display: none;
  }

  .color-swatch {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-full);
    border: 2px solid transparent;
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-spring);
  }

  .color-swatch:hover {
    transform: scale(1.2);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-full);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: background var(--duration-fast) var(--ease-out-cubic);
  }

  .theme-toggle:hover {
    background: var(--color-surface-elevated);
    color: var(--color-text-primary);
  }

  .icon-sun  { display: none; }
  .icon-moon { display: block; }
  [data-theme="dark"] .icon-sun  { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }

  .nav-bottom-border {
    height: 1px;
    background: var(--color-border-subtle);
  }

  .nav-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-3);
  }

  .nav-hamburger__bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: transform var(--duration-normal) var(--ease-out-cubic), opacity var(--duration-normal) var(--ease-out-cubic);
  }

  .nav-hamburger[aria-expanded="true"] .nav-hamburger__bar:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .nav-hamburger__bar:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--color-bg);
    z-index: var(--z-overlay);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out-cubic);
  }

  .mobile-menu[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    text-align: center;
  }

  .mobile-menu__list a {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 10vw, 4rem);
    font-weight: var(--weight-bold);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-cubic);
  }

  .mobile-menu__list a:hover,
  .mobile-menu__list a[aria-current="page"] {
    color: var(--color-accent);
  }

  /* ─── Responsive Adjustments ─── */
  @media (max-width: 768px) {
    .nav-links {
      display: none; /* Hide desktop links first */
    }
    
    .nav-hamburger {
      display: flex; /* Show hamburger */
    }
  }

  @media (max-width: 480px) {
    .nav-controls {
      gap: var(--space-2);
    }
    
    .theme-toggle {
      width: 30px;
      height: 30px;
    }
  }
</style>
