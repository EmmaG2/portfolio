---
const year = new Date().getFullYear()
---

<footer>
  <div class="footer-inner">
    <p class="footer-copy">
      &copy; {year} Fernando Granados
    </p>
    <nav aria-label="Social links" class="footer-social">
      <a
        href="https://github.com/EmmaG2"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/fernando-granados"
        target="_blank"
        rel="noopener noreferrer"
      >
        LinkedIn
      </a>
      <button id="footer-email-btn" type="button" class="footer-email-btn">Email</button>
      <script>
        const fb = document.getElementById('footer-email-btn')
        if (fb) {
          fb.addEventListener('click', () => {
            window.location.href = 'mailto:' + 'fergranados.dev' + '\x40' + 'outlook.com'
          })
        }
      </script>
    </nav>
  </div>
</footer>

<style>
  footer {
    padding: var(--space-8) var(--container-padding);
    border-top: 1px solid color-mix(in srgb, var(--color-text-primary) 8%, transparent);
  }

  .footer-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: var(--space-6);
  }

  .footer-social a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out-cubic);
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

  .footer-email-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out-cubic);
  }

  .footer-email-btn:hover {
    color: var(--color-accent);
  }
</style>
