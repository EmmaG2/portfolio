---
import BaseLayout from '../components/layout/BaseLayout.astro'
import SiteNav from '../components/layout/SiteNav.astro'
import SiteFooter from '../components/layout/SiteFooter.astro'
import HeroSection from '../components/home/HeroSection.astro'
import WorkPreview from '../components/home/WorkPreview.astro'
import AboutSnippet from '../components/home/AboutSnippet.astro'
import ContactBanner from '../components/home/ContactBanner.astro'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Fernando Granados',
  jobTitle: 'Senior Full Stack Engineer',
  url: 'https://fernandogranados.dev',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Durango',
    addressCountry: 'MX',
  },
  sameAs: [
    'https://github.com/EmmaG2',
    'https://linkedin.com/in/ingfergranados',
  ],
  knowsAbout: [
    'TypeScript', 'React', 'Next.js', 'Node.js',
    'FastAPI', 'PostgreSQL', 'Docker', 'Astro',
  ],
}
---

<BaseLayout
  title="Senior Full Stack Engineer & Product Builder"
  description="Senior Full Stack Engineer based in Durango, MX. 5+ years shipping products with React, Next.js, Node.js and FastAPI — from schema to production."
  structuredData={structuredData}
>
  <SiteNav slot="nav" currentPath={Astro.url.pathname} />
  <HeroSection />
  <WorkPreview />
  <AboutSnippet />
  <ContactBanner />
  <SiteFooter slot="footer" />
</BaseLayout>
